\section{Khái niệm đồ thị}

%-------------------------
\begin{frame}{Đồ thị là gì}

Đồ thị là cấu trúc gồm:

\[
G = (V,E)
\]

Trong đó

\begin{itemize}
\item $V$ : tập đỉnh
\item $E$ : tập cạnh nối giữa các đỉnh
\end{itemize}

Ví dụ đồ thị đơn giản

\begin{center}

\begin{tikzpicture}

\node[circle,draw] (A) at (0,0) {1};
\node[circle,draw] (B) at (2,0) {2};
\node[circle,draw] (C) at (1,1.5) {3};

\draw (A)--(B);
\draw (B)--(C);
\draw (C)--(A);

\end{tikzpicture}

\end{center}

\end{frame}

%-------------------------
\begin{frame}{Ứng dụng của đồ thị}

Đồ thị được dùng trong:

\begin{itemize}

\item mạng máy tính

\item mạng xã hội

\item bản đồ giao thông

\item tìm đường ngắn nhất

\item trí tuệ nhân tạo

\end{itemize}

\end{frame}

%=========================
\section{Biểu diễn đồ thị}

%-------------------------
\begin{frame}{Ma trận kề}

Ma trận kề dùng bảng $n \times n$

\[
A[i][j]
\]

\begin{itemize}

\item 1 : có cạnh

\item 0 : không có cạnh

\end{itemize}

Ví dụ

\[
\begin{bmatrix}
0 &1 &1\\
1 &0 &1\\
1 &1 &0
\end{bmatrix}
\]

\end{frame}

%-------------------------
\begin{frame}{Danh sách kề}

Ví dụ đồ thị

\begin{itemize}

\item 1 : 2 , 3

\item 2 : 1 , 3

\item 3 : 1 , 2

\end{itemize}

Ưu điểm

\begin{itemize}

\item tiết kiệm bộ nhớ

\item dùng tốt cho đồ thị lớn

\end{itemize}

\end{frame}

