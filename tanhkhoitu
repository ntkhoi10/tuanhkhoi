\section{BFS}

%-------------------------
\begin{frame}{Thuật toán BFS}

BFS là duyệt đồ thị theo chiều rộng.

Ý tưởng:

\begin{itemize}

\item duyệt theo từng lớp

\item sử dụng hàng đợi

\end{itemize}

Độ phức tạp

\[
O(V + E)
\]

\end{frame}

%-------------------------
\begin{frame}{Ví dụ BFS}

\begin{center}

\begin{tikzpicture}

\node[circle,draw] (1) at (0,0) {1};
\node[circle,draw] (2) at (2,0) {2};
\node[circle,draw] (3) at (4,0) {3};
\node[circle,draw] (4) at (1,1.5) {4};
\node[circle,draw] (5) at (3,1.5) {5};

\draw (1)--(2);
\draw (2)--(3);
\draw (1)--(4);
\draw (2)--(5);

\end{tikzpicture}

\end{center}

Thứ tự BFS

\[
1 \rightarrow 2 \rightarrow 4 \rightarrow 3 \rightarrow 5
\]

\end{frame}

%-------------------------
\begin{frame}{Cài đặt BFS bằng C++}

\begin{block}{Code}

\begin{verbatim}
#include <queue>

vector<int> a[100];
bool visited[100];

void BFS(int s)
{
 queue<int> q;

 q.push(s);
 visited[s] = true;

 while(!q.empty())
 {
  int u = q.front();
  q.pop();

  for(int v : a[u])
  {
   if(!visited[v])
   {
    visited[v] = true;
    q.push(v);
   }
  }
 }

}
\end{verbatim}

\end{block}

\end{frame}

